# backup.env.sample — Şablon (gerçek değerleri backup.env'e girin)
# KULLANIM: cp config/backup.env.sample config/backup.env

export DB_HOST="localhost"
export DB_PORT="5432"
export DB_NAME="hastane_db"
export DB_USER="backup_user"
export PGPASSWORD=""          # Güçlü bir parola girin

export APP_USER="hastane_app"
export APP_PASSWORD=""        # Güçlü bir parola girin

export BACKUP_DIR="${HOME}/postgresql-backups"
export WAL_ARCHIVE_DIR="${BACKUP_DIR}/wal_archive"

# Arch Linux: /var/lib/postgres/data
# Ubuntu:     /var/lib/postgresql/VERSION/main
export PG_DATA_DIR="/var/lib/postgres/data"
export PG_SERVICE="postgresql"

export RETENTION_DAYS=30
